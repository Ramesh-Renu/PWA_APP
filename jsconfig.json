{
  "compilerOptions": {
    "baseUrl": "src",
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@core/*": ["core/*"],
      "@hooks/*": ["hooks/*"],
      "@shared/*": ["shared/*"],
      "@assets/*": ["assets/*"],
      "components/*": ["components/*"],
      "pages/*": ["pages/*"],
      "store/*": ["store/*"],
      "services/*": ["services/*"],
      "styles/*": ["styles/*"],
      "assets/*": ["assets/*"],
      "config/*": ["config/*"],
      "constant/*": ["constant/*"],
      "utils/*": ["utils/*"],
      "theme/*": ["theme/*"]
    }
  },
  "include": ["src"]
}
